#!/usr/bin/env zsh
# Author: Víctor Falcón Ruíz <hi@victorfalcon.es>
# License: MIT
# git-worktree-new.sh
# Manages git worktrees with subcommand dispatch.
#
# Usage:
#   git-worktree-new.sh <branch-name>          # create (default)
#   git-worktree-new.sh new <branch-name>       # create
#   git-worktree-new.sh new -c <branch-name>    # create in current tab
#   git-worktree-new.sh <branch-name> -c        # create in current tab
#   git-worktree-new.sh ls                      # list worktrees
#   git-worktree-new.sh del [-f] [branch-name]  # delete
#   git-worktree-new.sh delete [-f] [branch-name] # delete
#   git-worktree-new.sh help                    # show help

set -e

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

typeset -a WT_SETUP_SCRIPT_PATHS=(
  "worktree.sh"
  ".local-dev/scripts/setup-worktree.sh"
)

WT_DEFAULT_BRANCH="${WT_DEFAULT_BRANCH:-}"
WT_WORKTREES_DIR="${WT_WORKTREES_DIR:-}"
WT_SCRIPT_NAME="$(basename -- "$0")"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_wt_git_check() {
  if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: not a git repository."
    exit 1
  fi
}

_wt_usage() {
  cat <<EOF
Usage:
  $WT_SCRIPT_NAME <branch-name>
  $WT_SCRIPT_NAME new [-c|--current-tab] <branch-name>
  $WT_SCRIPT_NAME <branch-name> [-c|--current-tab]
  $WT_SCRIPT_NAME ls
  $WT_SCRIPT_NAME del [-f|--force] [branch-name]
  $WT_SCRIPT_NAME delete [-f|--force] [branch-name]
  $WT_SCRIPT_NAME help

Options:
  -c, --current-tab  Reuse the current Zellij tab instead of opening a new one.
  -f, --force        Skip the uncommitted-changes prompt when deleting a worktree.

Config:
  WT_DEFAULT_BRANCH  Override the branch used for merged checks.
  WT_WORKTREES_DIR   Override the parent directory where worktrees are stored.

Behavior (new):
  - Creates worktrees under WT_WORKTREES_DIR/<repo-name>/<branch-name>
  - Defaults WT_WORKTREES_DIR to ../worktrees next to the repo root
  - Opens the worktree in a new Zellij tab when inside a Zellij session
  - With -c/--current-tab, renames and reuses the current tab instead

Behavior (ls):
  - Lists all worktrees for the current repository (excluding the main working tree)
  - Shows branch name, short commit hash, and path for each worktree

Behavior (del):
  - Removes the worktree for the given branch (or the current branch if omitted)
  - Prompts to force-remove if the worktree has uncommitted changes, unless -f/--force is set
  - Asks whether to delete the local branch after worktree removal
    - Merged branches default to Yes [Y/n], unmerged default to No [y/N]
  - When running inside Zellij, offers to close the current tab
EOF
}

_wt_repo_root() {
  git rev-parse --show-toplevel 2>/dev/null
}

_wt_default_branch() {
  local branch

  if [[ -n "$WT_DEFAULT_BRANCH" ]]; then
    echo "$WT_DEFAULT_BRANCH"
    return 0
  fi

  branch="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')"
  if [[ -z "$branch" ]]; then
    branch="$(git branch -r --format='%(refname:short)' 2>/dev/null | grep -E '/(main|master|trunk|develop)$' | head -1 | sed 's@.*/@@')"
  fi
  if [[ -z "$branch" ]]; then
    branch="$(git branch --format='%(refname:short)' 2>/dev/null | grep -E '^(main|master|trunk|develop)$' | head -1)"
  fi
  echo "${branch:-main}"
}

# Returns 0 if the branch is fully merged (regular or squash) into default branch.
_wt_is_merged() {
  local branch="$1" default_branch="$2"

  # Regular merge: branch tip is an ancestor of default branch
  if git merge-base --is-ancestor "$branch" "$default_branch" 2>/dev/null; then
    return 0
  fi

  # Squash merge detection via commit-tree + git-cherry:
  # Create a hypothetical single commit that represents the cumulative diff of the
  # branch over the merge-base, then check if an equivalent patch already exists in
  # the default branch.
  local merge_base test_commit cherry_result
  merge_base="$(git merge-base "$default_branch" "$branch" 2>/dev/null)" || return 1
  [[ -z "$merge_base" ]] && return 1

  test_commit="$(git commit-tree "${branch}^{tree}" -p "$merge_base" -m "__wt_squash_test__" 2>/dev/null)" || return 1
  [[ -z "$test_commit" ]] && return 1

  cherry_result="$(git cherry "$default_branch" "$test_commit" 2>/dev/null)" || return 1

  # "- <hash>" means an equivalent patch was found in default_branch (squash merged).
  # Empty result means the branch introduced no changes (already up-to-date).
  if [[ "$cherry_result" == "- "* ]] || [[ -z "$cherry_result" ]]; then
    return 0
  fi

  return 1
}

_wt_worktree_exists() {
  local target_path="$1" line current_path=""

  while IFS= read -r line; do
    if [[ "$line" == worktree\ * ]]; then
      current_path="${line#worktree }"
      if [[ "$current_path" == "$target_path" ]]; then
        return 0
      fi
    fi
  done < <(git worktree list --porcelain)

  return 1
}

_wt_worktree_path_for_branch() {
  local branch_ref="refs/heads/$1" line current_path=""

  while IFS= read -r line; do
    if [[ "$line" == worktree\ * ]]; then
      current_path="${line#worktree }"
    elif [[ "$line" == "branch $branch_ref" ]]; then
      printf '%s\n' "$current_path"
      return 0
    fi
  done < <(git worktree list --porcelain)

  return 1
}

# ---------------------------------------------------------------------------
# List worktrees
# ---------------------------------------------------------------------------

_wt_list() {
  _wt_git_check

  local main_worktree line current_path="" current_branch="" current_head=""
  local is_bare=false count=0
  local -a paths branches heads

  main_worktree="$(_wt_repo_root)"

  _wt_list_flush() {
    # Skip the main worktree and bare entries
    if [[ -n "$current_path" && "$current_path" != "$main_worktree" ]] && ! $is_bare; then
      paths+=("$current_path")
      branches+=("${current_branch:-(detached)}")
      heads+=("${current_head:-unknown}")
    fi
  }

  while IFS= read -r line; do
    if [[ "$line" == worktree\ * ]]; then
      _wt_list_flush
      current_path="${line#worktree }"
      current_branch=""
      current_head=""
      is_bare=false
    elif [[ "$line" == branch\ * ]]; then
      current_branch="${line#branch refs/heads/}"
    elif [[ "$line" == HEAD\ * ]]; then
      current_head="${line#HEAD }"
    elif [[ "$line" == "bare" ]]; then
      is_bare=true
    fi
  done < <(git worktree list --porcelain)

  # Flush the last entry
  _wt_list_flush
  unfunction _wt_list_flush

  if (( ${#paths[@]} == 0 )); then
    echo "No worktrees found (other than the main working tree)."
    return 0
  fi

  echo ""
  echo "  Worktrees for $(basename "$main_worktree"):"
  echo ""

  local i
  for (( i = 1; i <= ${#paths[@]}; i++ )); do
    local short_head="${heads[$i]:0:8}"
    echo "  ${branches[$i]}  ${short_head}  ${paths[$i]}"
  done

  echo ""
  echo "  ${#paths[@]} worktree(s)"
  echo ""
}

# ---------------------------------------------------------------------------
# Create worktree
# ---------------------------------------------------------------------------

_wt_new() {
  local CURRENT_TAB=false
  local BRANCH_NAME=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -c|--current-tab)
        CURRENT_TAB=true
        shift
        ;;
      -*)
        echo "Error: unknown option '$1'."
        echo "Usage: $WT_SCRIPT_NAME [new] [-c|--current-tab] <branch-name>"
        exit 1
        ;;
      *)
        if [[ -n "$BRANCH_NAME" ]]; then
          echo "Error: unexpected argument '$1'."
          echo "Usage: $WT_SCRIPT_NAME [new] [-c|--current-tab] <branch-name>"
          exit 1
        fi
        BRANCH_NAME="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$BRANCH_NAME" ]]; then
    echo "Error: branch name is required."
    echo "Usage: $WT_SCRIPT_NAME [new] [-c|--current-tab] <branch-name>"
    exit 1
  fi

  _wt_git_check

  local ORIGIN_DIR FOLDER_NAME WORKTREE_ROOT WORKTREE_PATH
  ORIGIN_DIR="$(_wt_repo_root)"
  FOLDER_NAME="$(basename "$ORIGIN_DIR")"
  WORKTREE_ROOT="${WT_WORKTREES_DIR:-$(dirname "$ORIGIN_DIR")/worktrees}"
  WORKTREE_PATH="$WORKTREE_ROOT/$FOLDER_NAME/$BRANCH_NAME"

  mkdir -p "$(dirname "$WORKTREE_PATH")"

  git fetch origin 2>/dev/null || echo "Warning: could not fetch from origin"

  if _wt_worktree_exists "$WORKTREE_PATH"; then
    echo "Worktree already exists at $WORKTREE_PATH — opening tab."
  elif [[ -e "$WORKTREE_PATH" ]]; then
    echo "Error: path already exists but is not a registered worktree: $WORKTREE_PATH"
    exit 1
  elif git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    git worktree add "$WORKTREE_PATH" "$BRANCH_NAME" 2>&1
  else
    local DEFAULT_BRANCH
    DEFAULT_BRANCH="$(_wt_default_branch)"
    git worktree add -b "$BRANCH_NAME" "$WORKTREE_PATH" "origin/$DEFAULT_BRANCH" 2>&1
  fi

  # Bail out gracefully when not inside a Zellij session
  if [[ -z "${ZELLIJ:-}" ]]; then
    echo "Not in a Zellij session — navigate manually to: $WORKTREE_PATH"
    exit 0
  fi

  # Pick a setup script if one exists in the origin repo
  local SETUP_SCRIPT=""
  local relative_setup_script
  for relative_setup_script in "${WT_SETUP_SCRIPT_PATHS[@]}"; do
    if [[ -f "$ORIGIN_DIR/$relative_setup_script" ]]; then
      SETUP_SCRIPT="$WORKTREE_PATH/$relative_setup_script"
      break
    fi
  done

  # Write a self-deleting temp script that zellij will run in the new tab.
  local TMPSCRIPT LAUNCH_COMMAND CD_COMMAND
  TMPSCRIPT="$(mktemp "${TMPDIR:-/tmp}/wt-setup.XXXXXX")"
  cat > "$TMPSCRIPT" <<'EOF'
#!/usr/bin/env zsh

TMPSCRIPT="$1"
WORKTREE_PATH="$2"
BRANCH_NAME="$3"
SETUP_SCRIPT="$4"
ORIGIN_DIR="$5"

rm -f -- "$TMPSCRIPT"
cd -- "$WORKTREE_PATH"

echo ""
echo "  Worktree : $WORKTREE_PATH"
echo "  Branch   : $BRANCH_NAME"

if [[ -n "$SETUP_SCRIPT" ]]; then
  echo "  Setup    : running $(basename "$SETUP_SCRIPT")"
  echo ""
  if [[ ! -x "$SETUP_SCRIPT" ]]; then
    if [[ -w "$SETUP_SCRIPT" ]]; then
      chmod +x "$SETUP_SCRIPT"
    else
      echo "Setup script is not executable. Password required to fix permissions."
      sudo -v
      sudo chmod +x "$SETUP_SCRIPT"
    fi
  fi
  "$SETUP_SCRIPT" "$ORIGIN_DIR"
else
  echo "  Setup    : no worktree script found, skipping."
  echo ""
fi

exec "${SHELL:-/bin/zsh}"
EOF
  chmod +x "$TMPSCRIPT"

  LAUNCH_COMMAND="$(printf '%q ' "$TMPSCRIPT" "$TMPSCRIPT" "$WORKTREE_PATH" "$BRANCH_NAME" "$SETUP_SCRIPT" "$ORIGIN_DIR")"
  LAUNCH_COMMAND="${LAUNCH_COMMAND% }"
  CD_COMMAND="cd -- $(printf '%q' "$WORKTREE_PATH")"

  if $CURRENT_TAB; then
    zellij action rename-tab "󰔱 $BRANCH_NAME"
    zellij action write-chars "$CD_COMMAND"
    zellij action write 10  # send Enter
    sleep 0.1
    zellij action write-chars "$LAUNCH_COMMAND"
    zellij action write 10  # send Enter
  else
    zellij action new-tab --cwd "$WORKTREE_PATH" --name "󰔱 $BRANCH_NAME"
    sleep 0.3
    zellij action write-chars "$CD_COMMAND"
    zellij action write 10  # send Enter
    sleep 0.1
    zellij action write-chars "$LAUNCH_COMMAND"
    zellij action write 10  # send Enter
  fi
}

# ---------------------------------------------------------------------------
# Delete worktree
# ---------------------------------------------------------------------------

_wt_delete() {
  local FORCE=false
  local BRANCH_NAME=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force)
        FORCE=true
        shift
        ;;
      -*)
        echo "Error: unknown option '$1'."
        echo "Usage: $WT_SCRIPT_NAME del [-f|--force] [branch-name]"
        exit 1
        ;;
      *)
        if [[ -n "$BRANCH_NAME" ]]; then
          echo "Error: unexpected argument '$1'."
          echo "Usage: $WT_SCRIPT_NAME del [-f|--force] [branch-name]"
          exit 1
        fi
        BRANCH_NAME="$1"
        shift
        ;;
    esac
  done

  _wt_git_check

  # If no branch name given, try to detect from current location
  if [[ -z "$BRANCH_NAME" ]]; then
    BRANCH_NAME="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || true
    if [[ -z "$BRANCH_NAME" || "$BRANCH_NAME" == "HEAD" ]]; then
      echo "Error: branch name is required."
      echo "Usage: $WT_SCRIPT_NAME del [-f|--force] [branch-name]"
      exit 1
    fi
    echo "Detected branch: $BRANCH_NAME"
  fi

  # Find the registered worktree for this branch
  local WORKTREE_PATH
  WORKTREE_PATH="$(_wt_worktree_path_for_branch "$BRANCH_NAME")"

  if [[ -z "$WORKTREE_PATH" ]]; then
    echo "Error: no worktree found for branch '$BRANCH_NAME'."
    exit 1
  fi

  # Remove the worktree directory
  echo "Removing worktree at $WORKTREE_PATH ..."
  if $FORCE; then
    git worktree remove --force "$WORKTREE_PATH"
  elif ! git worktree remove "$WORKTREE_PATH" 2>/dev/null; then
    printf "Worktree has uncommitted changes. Force remove? [y/N] "
    local ans
    read -r ans || true
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      git worktree remove --force "$WORKTREE_PATH"
    else
      echo "Aborted."
      exit 1
    fi
  fi

  # Check if the local branch still exists
  if ! git show-ref --verify --quiet "refs/heads/$BRANCH_NAME"; then
    echo "Branch '$BRANCH_NAME' no longer exists locally. Done."
    # Offer to close the current Zellij tab
    if [[ -n "${ZELLIJ:-}" ]]; then
      printf "Close current Zellij tab? [y/N] "
      local close_tab
      read -r close_tab || true
      if [[ "$close_tab" =~ ^[Yy]$ ]]; then
        zellij action close-tab
      fi
    fi
    return 0
  fi

  local DEFAULT_BRANCH
  DEFAULT_BRANCH="$(_wt_default_branch)"

  local is_merged=false
  if _wt_is_merged "$BRANCH_NAME" "$DEFAULT_BRANCH"; then
    is_merged=true
  fi

  echo ""
  if $is_merged; then
    echo "Branch '$BRANCH_NAME' is merged into '$DEFAULT_BRANCH'."
    printf "Delete the branch? [Y/n] "
  else
    echo "Branch '$BRANCH_NAME' has not been merged into '$DEFAULT_BRANCH'."
    printf "Delete the branch anyway? [y/N] "
  fi

  local answer
  read -r answer || true

  if $is_merged; then
    # Default is Yes for merged branches
    if [[ -z "$answer" || "$answer" =~ ^[Yy]$ ]]; then
      git branch -d "$BRANCH_NAME"
      echo "Branch deleted."
    else
      echo "Branch kept."
    fi
  else
    # Default is No for unmerged branches
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      git branch -D "$BRANCH_NAME"
      echo "Branch deleted."
    else
      echo "Branch kept."
    fi
  fi

  # Offer to close the current Zellij tab
  if [[ -n "${ZELLIJ:-}" ]]; then
    printf "Close current Zellij tab? [y/N] "
    local close_tab
    read -r close_tab || true
    if [[ "$close_tab" =~ ^[Yy]$ ]]; then
      zellij action close-tab
    fi
  fi
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "$1" in
  help|-h|--help)
    _wt_usage
    ;;
  ls|list)
    shift
    _wt_list "$@"
    ;;
  del|delete)
    shift
    _wt_delete "$@"
    ;;
  new)
    shift
    _wt_new "$@"
    ;;
  *)
    # Default: treat first arg as branch name for create
    _wt_new "$@"
    ;;
esac
